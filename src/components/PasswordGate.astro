---
// Password gate component — blocks site until correct password is entered
// Password is checked client-side; this is a simple "coming soon" gate, not security-critical
---

<div id="password-gate" class="gate">
  <div class="gate-card">
    <h1 class="gate-title">Mantle Cell Lymphoma Alliance</h1>
    <p class="gate-message">Thanks for your interest. This website will be ready soon.</p>
    <form id="gate-form" class="gate-form">
      <div class="gate-input-wrap">
        <input
          type="password"
          id="gate-password"
          class="gate-input"
          placeholder="Enter password"
          autocomplete="off"
          autofocus
        />
        <button type="submit" class="gate-btn" aria-label="Submit password">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>
      <p id="gate-error" class="gate-error" aria-live="polite"></p>
    </form>
  </div>
</div>

<style>
  .gate {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #FAFAF8;
    font-family: 'Inter', system-ui, sans-serif;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .gate.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .gate-card {
    text-align: center;
    max-width: 440px;
    padding: 2rem 1.5rem;
  }

  .gate-title {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #0D7377;
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .gate-message {
    font-size: 1.05rem;
    color: #4A5568;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .gate-form {
    width: 100%;
  }

  .gate-input-wrap {
    display: flex;
    gap: 0;
    border: 2px solid #CBD5E0;
    border-radius: 0.5rem;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .gate-input-wrap:focus-within {
    border-color: #0D7377;
  }

  .gate-input-wrap.shake {
    animation: shake 0.4s ease;
    border-color: #E8614D;
  }

  .gate-input {
    flex: 1;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: inherit;
    border: none;
    outline: none;
    background: white;
    color: #2D3748;
  }

  .gate-input::placeholder {
    color: #A0AEC0;
  }

  .gate-btn {
    padding: 0.75rem 1rem;
    background: #0D7377;
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .gate-btn:hover {
    background: #0A5C5F;
  }

  .gate-error {
    margin: 0.75rem 0 0;
    font-size: 0.875rem;
    color: #E8614D;
    min-height: 1.25rem;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-8px); }
    40% { transform: translateX(8px); }
    60% { transform: translateX(-6px); }
    80% { transform: translateX(6px); }
  }
</style>

<script>
  const STORAGE_KEY = 'mcla_gate_auth';
  const CORRECT_PASSWORD = 'strongerthanmantle';

  const gate = document.getElementById('password-gate');
  const form = document.getElementById('gate-form');
  const input = document.getElementById('gate-password') as HTMLInputElement;
  const error = document.getElementById('gate-error');
  const wrap = document.querySelector('.gate-input-wrap');

  // Check if already authenticated
  if (localStorage.getItem(STORAGE_KEY) === 'true') {
    gate?.classList.add('hidden');
    // Remove from DOM after transition
    setTimeout(() => { if (gate) gate.style.display = 'none'; }, 400);
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const value = input?.value.trim();

    if (value === CORRECT_PASSWORD) {
      localStorage.setItem(STORAGE_KEY, 'true');
      gate?.classList.add('hidden');
      setTimeout(() => { if (gate) gate.style.display = 'none'; }, 400);
    } else {
      // Shake animation
      wrap?.classList.remove('shake');
      void (wrap as HTMLElement)?.offsetWidth; // trigger reflow
      wrap?.classList.add('shake');
      if (error) error.textContent = 'Incorrect password';
      input?.select();
    }
  });
</script>
