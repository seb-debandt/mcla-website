---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

{posts.length > 0 && (
  <section class="py-20 md:py-28 bg-warm-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-8 items-end mb-12">
        <div>
          <div class="inline-flex items-center gap-2 text-teal text-[13px] font-extrabold uppercase mb-4">
            <span class="block w-7 h-0.5 bg-amber"></span>
            Latest from MCLA
          </div>
          <h2 class="text-3xl md:text-5xl font-extrabold text-text-dark tracking-[-0.5px] max-w-3xl mb-4">
            Stories, updates, and expert guidance from the MCL community.
          </h2>
          <p class="text-text-mid text-lg leading-relaxed max-w-2xl">
            Keep up with the newest MCLA articles, research updates, and community news.
          </p>
        </div>
        <a
          href="/news/"
          class="inline-flex items-center justify-center w-fit min-h-11 px-5 border border-teal/30 rounded-full bg-white/70 text-teal text-sm font-extrabold hover:bg-white hover:border-teal transition-colors no-underline"
        >
          View all news
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a
            href={`/news/${post.id}`}
            class="group flex flex-col min-h-full bg-white rounded-lg overflow-hidden border border-border hover:shadow-xl transition-all duration-300 no-underline"
          >
            <div class="aspect-[16/9] bg-gradient-to-br from-teal/15 to-amber/10 flex items-center justify-center overflow-hidden">
              {post.data.featuredImage ? (
                <img
                  src={post.data.featuredImage}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <span class="text-teal/45 text-sm font-semibold">Featured Image</span>
              )}
            </div>
            <div class="flex flex-col flex-1 p-6">
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span class="inline-flex items-center min-h-6 px-2.5 bg-teal/10 text-teal text-xs font-extrabold rounded-full">
                  {post.data.category}
                </span>
                <time class="text-text-light text-xs font-semibold" datetime={new Date(post.data.date).toISOString()}>
                  {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h3 class="text-xl font-extrabold text-text-dark leading-snug mb-3 group-hover:text-teal transition-colors">
                {post.data.title}
              </h3>
              <p class="text-text-mid text-sm leading-relaxed line-clamp-3 mb-6">{post.data.excerpt}</p>
              <div class="mt-auto text-teal font-extrabold text-sm">Read more &rarr;</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
