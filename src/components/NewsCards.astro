---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<section class="py-20 md:py-28 bg-warm-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-14 gap-4">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-text-dark mb-2">Latest News</h2>
        <p class="text-text-mid text-lg">Updates from the MCLA community.</p>
      </div>
      <a
        href="/news"
        class="inline-flex items-center text-teal font-semibold hover:gap-2 transition-all no-underline"
      >
        View all news
        <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {posts.map((post) => (
        <a href={`/news/${post.id}`} class="group block bg-white rounded-2xl overflow-hidden border border-border hover:shadow-lg transition-all duration-300 no-underline">
          <!-- Image placeholder -->
          <div class="aspect-[16/9] bg-gradient-to-br from-teal/20 to-warm-white flex items-center justify-center">
            <span class="text-teal/40 text-sm font-medium">Featured Image</span>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="inline-block px-2.5 py-0.5 bg-teal/10 text-teal text-xs font-semibold rounded-full">
                {post.data.category}
              </span>
              <time class="text-text-light text-xs" datetime={new Date(post.data.date).toISOString()}>
                {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h3 class="text-lg font-bold text-text-dark mb-2 group-hover:text-teal transition-colors">{post.data.title}</h3>
            <p class="text-text-mid text-sm line-clamp-2">{post.data.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
