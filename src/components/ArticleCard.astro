---
interface Props {
  title: string;
  /** 'full' for the standalone article-page header; 'compact' for a listing thumbnail (fills its parent). */
  size?: 'full' | 'compact';
}

const { title, size = 'full' } = Astro.props;

const parts = title.split(' + ');
---

<div
  class:list={[
    'flex items-center bg-warm-white overflow-hidden [container-type:inline-size]',
    size === 'full'
      ? 'aspect-[16/9] rounded-2xl border border-border px-[7%]'
      : 'w-full h-full px-[6%]',
  ]}
>
  <h2
    class:list={[
      'font-black text-text-dark leading-[1.05] [text-wrap:balance] [word-break:normal] [overflow-wrap:break-word]',
      size === 'full'
        ? 'text-[clamp(22px,8cqi,60px)] tracking-[-1.2px]'
        : 'text-[clamp(14px,7.5cqi,28px)] tracking-[-0.5px]',
    ]}
  >
    {parts.map((part, i) => (
      <>
        {i > 0 && <span class="text-amber px-[0.06em]">+</span>}
        {part}
      </>
    ))}
  </h2>
</div>
