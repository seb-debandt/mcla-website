<section class="py-20 md:py-24 bg-gradient-to-br from-coral/5 via-warm-white to-gold/5">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">
      Every Gift Brings Us Closer
    </h2>
    <p class="text-charcoal/60 text-lg mb-10 max-w-2xl mx-auto">
      Your generosity directly funds research, patient education, and support programs for the MCL community. Together, we can advance better treatments and work toward a cure.
    </p>
    <a
      href="/donate"
      class="inline-flex items-center px-8 py-4 bg-coral hover:bg-coral-dark text-white font-bold text-lg rounded-lg transition-colors no-underline shadow-lg shadow-coral/20"
    >
      Donate Now
      <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
    </a>
  </div>
</section>
