---
---
<form
  name="contact"
  method="POST"
  data-netlify="true"
  class="space-y-6"
>
  <input type="hidden" name="form-name" value="contact" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="contact-name" class="block text-sm font-medium text-text-dark mb-1.5">Full Name</label>
      <input
        type="text"
        name="name"
        id="contact-name"
        required
        class="w-full px-6 py-4 border-2 border-[#d8d4ce] rounded-full text-text-dark placeholder-text-light focus:outline-none focus:border-teal bg-cream transition-colors duration-200 text-[15px]"
        placeholder="Your name"
      />
    </div>
    <div>
      <label for="contact-email" class="block text-sm font-medium text-text-dark mb-1.5">Email</label>
      <input
        type="email"
        name="email"
        id="contact-email"
        required
        class="w-full px-6 py-4 border-2 border-[#d8d4ce] rounded-full text-text-dark placeholder-text-light focus:outline-none focus:border-teal bg-cream transition-colors duration-200 text-[15px]"
        placeholder="you@example.com"
      />
    </div>
  </div>

  <div>
    <label for="contact-subject" class="block text-sm font-medium text-text-dark mb-1.5">Subject</label>
    <select
      name="subject"
      id="contact-subject"
      required
      class="w-full px-6 py-4 border-2 border-[#d8d4ce] rounded-full text-text-dark focus:outline-none focus:border-teal bg-cream transition-colors duration-200 text-[15px]"
    >
      <option value="">Select a topic</option>
      <option value="general">General Inquiry</option>
      <option value="patient">Patient Resources</option>
      <option value="research">Research Collaboration</option>
      <option value="volunteer">Volunteering</option>
      <option value="partnership">Partnership Opportunities</option>
      <option value="donation">Donation Questions</option>
      <option value="media">Media Inquiry</option>
      <option value="other">Other</option>
    </select>
  </div>

  <div>
    <label for="contact-message" class="block text-sm font-medium text-text-dark mb-1.5">Message</label>
    <textarea
      name="message"
      id="contact-message"
      rows="5"
      required
      class="w-full px-6 py-4 border-2 border-[#d8d4ce] rounded-2xl text-text-dark placeholder-text-light focus:outline-none focus:border-teal bg-cream transition-colors duration-200 resize-y text-[15px]"
      placeholder="How can we help?"
    ></textarea>
  </div>

  <button
    type="submit"
    class="px-9 py-4 bg-teal hover:bg-teal-light text-white font-bold rounded-full transition-all duration-200 hover:-translate-y-[1px] tracking-[0.3px]"
  >
    Send Message
  </button>
</form>
