---
import { getCollection } from 'astro:content';

// Map content slugs to their URL paths
const slugToHref: Record<string, string> = {
  'mission': '/about/mission',
  'our-story': '/about/our-story',
  'what-is-mcl': '/understanding-mcl/what-is-mcl',
  'newly-diagnosed': '/understanding-mcl/newly-diagnosed',
  'treatment-options': '/understanding-mcl/treatment-options',
  'find-specialist': '/understanding-mcl/find-specialist',
  'caregiver-support': '/understanding-mcl/caregiver-support',
  'research': '/research',
  'research-priorities': '/research/priorities',
  'for-researchers': '/research/for-researchers',
  'get-involved': '/get-involved',
  'volunteer': '/get-involved/volunteer',
  'partner': '/get-involved/partner',
  'contact': '/contact',
  'donate': '/donate',
  'home': '/',
};

// Build nav dynamically from CMS data
const allPages = await getCollection('pages');
const menuPages = allPages.filter(p => !p.data.draft && p.data.navMenu && p.data.navMenu !== 'None');

// Group by navMenu, sort by navOrder
const groups: Record<string, { label: string; href: string; order: number }[]> = {};
for (const page of menuPages) {
  const menu = page.data.navMenu!;
  if (!groups[menu]) groups[menu] = [];
  groups[menu].push({
    label: page.data.navLabel || page.data.title,
    href: slugToHref[page.id] || `/${page.id}`,
    order: page.data.navOrder ?? 99,
  });
}
for (const key of Object.keys(groups)) {
  groups[key].sort((a, b) => a.order - b.order);
}

// Hardcoded items for pages not in the pages collection
const hardcodedChildren: Record<string, { label: string; href: string; order: number }[]> = {
  'About': [{ label: 'Our Team', href: '/about/team', order: 3 }],
};

// Merge hardcoded items into groups
for (const [menu, items] of Object.entries(hardcodedChildren)) {
  if (!groups[menu]) groups[menu] = [];
  groups[menu].push(...items);
  groups[menu].sort((a, b) => a.order - b.order);
}

type NavChild = { label: string; href: string };
type NavItem = { label: string; href?: string; children?: NavChild[] };

// Define menu group display order
const menuOrder = ['About', 'Understanding MCL', 'Research'];
const dropdownItems: NavItem[] = menuOrder
  .filter(name => groups[name]?.length)
  .map(name => ({ label: name, children: groups[name].map(({ label, href }) => ({ label, href })) }));

// News is hardcoded (from blog collection, not pages)
const newsItem: NavItem = { label: 'News', href: '/news' };

// Get Involved dropdown
const getInvolvedItem: NavItem | null = groups['Get Involved']?.length
  ? { label: 'Get Involved', children: groups['Get Involved'].map(({ label, href }) => ({ label, href })) }
  : null;

// Top Level items (like Contact)
const topLevelItems: NavItem[] = (groups['Top Level'] || [])
  .map(({ label, href }) => ({ label, href }));

const navItems: NavItem[] = [
  ...dropdownItems,
  ...(getInvolvedItem ? [getInvolvedItem] : []),
  ...topLevelItems,
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-border transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-6 lg:px-12" aria-label="Main navigation">
    <div class="flex items-center justify-between h-18 lg:h-20">
      <!-- Stacked Color-Block Logo -->
      <a href="/" class="no-underline shrink-0" aria-label="MCLA Home">
        <div class="flex flex-col gap-[2px] items-start">
          <span class="bg-teal text-white font-black text-[11px] tracking-[1.5px] leading-[1.3] px-2.5 py-[3px] rounded-[3px] w-fit whitespace-nowrap">MANTLE CELL</span>
          <span class="bg-amber text-white font-black text-[11px] tracking-[1.5px] leading-[1.3] px-2.5 py-[3px] rounded-[3px] w-fit whitespace-nowrap">LYMPHOMA</span>
          <span class="bg-teal-deep text-white font-black text-[11px] tracking-[1.5px] leading-[1.3] px-2.5 py-[3px] rounded-[3px] w-fit whitespace-nowrap">ALLIANCE</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <div class="relative group">
            {item.children ? (
              <>
                <button
                  class="px-3 py-2 text-[15px] text-text-dark/80 hover:text-teal transition-colors flex items-center gap-1 font-semibold tracking-[0.2px]"
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  {item.label}
                  <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                  <div class="bg-white rounded-xl shadow-lg border border-border py-2 min-w-[220px]">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="block px-4 py-2.5 text-sm text-text-dark/80 hover:text-teal hover:bg-cream transition-colors no-underline"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class="px-3 py-2 text-[15px] text-text-dark/80 hover:text-teal transition-colors font-semibold tracking-[0.2px] no-underline"
              >
                {item.label}
              </a>
            )}
          </div>
        ))}
      </div>

      <!-- Mobile Toggle -->
      <div class="flex items-center gap-3">
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-text-dark hover:text-teal transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" id="menu-open-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden" id="menu-close-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-white border-t border-border overflow-y-auto max-h-[calc(100vh-4.5rem)]"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <div>
          {item.children ? (
            <div class="mobile-dropdown">
              <button
                class="w-full flex items-center justify-between px-3 py-3 text-text-dark/80 font-semibold hover:text-teal transition-colors text-left"
                aria-expanded="false"
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="hidden pl-4 pb-2 space-y-1">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-3 py-2 text-sm text-text-mid hover:text-teal transition-colors no-underline"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="block px-3 py-3 text-text-dark/80 font-semibold hover:text-teal transition-colors no-underline"
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    menuBtn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });

  // Mobile dropdown toggles
  document.querySelectorAll('.mobile-dropdown button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const arrow = btn.querySelector('svg');
      const isOpen = content?.classList.toggle('hidden') === false;
      arrow?.classList.toggle('rotate-180', isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // Sticky header compact on scroll
  const header = document.getElementById('site-header');
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 50) {
      header?.classList.add('shadow-sm');
    } else {
      header?.classList.remove('shadow-sm');
    }
    lastScroll = currentScroll;
  }, { passive: true });
</script>
