---
---
<section class="py-16 md:py-20 bg-white">
  <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
    <div class="section-label">STAY CONNECTED</div>
    <h2 class="text-2xl md:text-3xl font-extrabold text-text-dark tracking-[-0.5px] mb-3">Stay Informed. Join Our Community.</h2>
    <p class="text-text-mid mb-8 max-w-xl mx-auto">
      Receive the latest updates on MCL research, patient resources, and community events delivered to your inbox.
    </p>
    <div id="newsletter-wrapper">
      <form
        id="newsletter-form"
        class="flex flex-col gap-3 max-w-lg mx-auto"
      >
        <div class="flex flex-col sm:flex-row gap-3">
          <label for="newsletter-first-name" class="sr-only">First name</label>
          <input
            type="text"
            name="first_name"
            id="newsletter-first-name"
            required
            placeholder="First name"
            class="flex-1 px-6 py-4 border-2 border-[#d8d4ce] rounded-full text-text-dark placeholder-text-light focus:outline-none focus:border-teal text-[15px] bg-cream transition-colors duration-200"
          />
          <label for="newsletter-last-name" class="sr-only">Last name</label>
          <input
            type="text"
            name="last_name"
            id="newsletter-last-name"
            required
            placeholder="Last name"
            class="flex-1 px-6 py-4 border-2 border-[#d8d4ce] rounded-full text-text-dark placeholder-text-light focus:outline-none focus:border-teal text-[15px] bg-cream transition-colors duration-200"
          />
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            type="email"
            name="email"
            id="newsletter-email"
            required
            placeholder="Your email address"
            class="flex-1 px-6 py-4 border-2 border-[#d8d4ce] rounded-full text-text-dark placeholder-text-light focus:outline-none focus:border-teal text-[15px] bg-cream transition-colors duration-200"
          />
          <button
            type="submit"
            id="newsletter-btn"
            class="px-7 py-4 bg-teal hover:bg-teal-light text-white font-bold rounded-full transition-all duration-200 hover:-translate-y-[1px] whitespace-nowrap tracking-[0.3px]"
          >
            Subscribe
          </button>
        </div>
        <div class="flex items-start gap-3 text-left mt-1 max-w-md mx-auto">
          <input
            type="checkbox"
            name="marketing_consent"
            id="newsletter-consent"
            required
            class="mt-1 w-4 h-4 accent-teal rounded border-[#d8d4ce] cursor-pointer shrink-0"
          />
          <label for="newsletter-consent" class="text-text-light text-xs leading-relaxed cursor-pointer">
            I agree to receive email communications from MCLA, including newsletters, research updates, and event information. You can unsubscribe at any time. See our <a href="/privacy-policy" class="underline hover:text-teal transition-colors duration-200">Privacy Policy</a>.
          </label>
        </div>
      </form>
      <p id="newsletter-error" class="text-red-600 text-sm mt-3 hidden"></p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("newsletter-form");
  const btn = document.getElementById("newsletter-btn");
  const wrapper = document.getElementById("newsletter-wrapper");
  const errorEl = document.getElementById("newsletter-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl?.classList.add("hidden");

    const data = new FormData(form);
    const first_name = data.get("first_name");
    const last_name = data.get("last_name");
    const email = data.get("email");
    const consent = document.getElementById("newsletter-consent");
    if (!email || !first_name || !last_name) return;

    if (!consent?.checked) {
      errorEl.textContent = "Please confirm you agree to receive email communications.";
      errorEl?.classList.remove("hidden");
      return;
    }

    btn.disabled = true;
    btn.textContent = "Sending...";

    try {
      const res = await fetch("/.netlify/functions/newsletter-signup", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, first_name, last_name, marketing_consent: true }),
      });

      if (res.ok) {
        wrapper.innerHTML = `
          <div class="py-4 text-teal font-bold text-lg">
            Thank you for subscribing!
          </div>
        `;
      } else {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || "Something went wrong");
      }
    } catch (err) {
      errorEl.textContent = err.message || "Something went wrong. Please try again.";
      errorEl?.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Subscribe";
    }
  });
</script>
