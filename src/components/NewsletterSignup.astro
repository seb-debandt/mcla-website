---
---
<section class="py-16 md:py-20 bg-warm-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-3">Stay Informed. Join Our Community.</h2>
    <p class="text-charcoal/60 mb-8 max-w-xl mx-auto">
      Receive the latest updates on MCL research, patient resources, and community events delivered to your inbox.
    </p>
    <form
      name="newsletter"
      method="POST"
      data-netlify="true"
      class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
    >
      <input type="hidden" name="form-name" value="newsletter" />
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        type="email"
        name="email"
        id="newsletter-email"
        required
        placeholder="Your email address"
        class="flex-1 px-4 py-3 border border-sage-dark rounded-lg text-charcoal placeholder-charcoal/40 focus:outline-none focus:ring-2 focus:ring-teal-primary focus:border-transparent text-[15px]"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-teal-primary hover:bg-teal-dark text-white font-semibold rounded-lg transition-colors whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="text-charcoal/40 text-xs mt-4">
      We respect your privacy. Unsubscribe at any time.
    </p>
  </div>
</section>
