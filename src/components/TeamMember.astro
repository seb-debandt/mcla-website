---
interface Props {
  name: string;
  title: string;
  bio: string;
  roleType?: string;
  photo?: string;
}

const { name, title, bio, roleType = 'staff', photo } = Astro.props;
---

<div class="bg-white rounded-2xl border border-border p-6 hover:shadow-md transition-all duration-200">
  <div class="flex items-start gap-5">
    {photo ? (
      <img src={photo} alt={name} class="w-20 h-20 rounded-xl object-cover shrink-0" />
    ) : (
      <div class="w-20 h-20 bg-gradient-to-br from-teal/20 to-warm-white rounded-xl flex items-center justify-center shrink-0">
        <span class="text-teal font-bold text-xl ">
          {name.split(' ').map(n => n[0]).join('')}
        </span>
      </div>
    )}
    <div>
      <h3 class="text-lg font-bold text-text-dark">{name}</h3>
      <p class="text-teal text-sm font-medium mb-2">{title}</p>
      {roleType && (
        <span class="inline-block px-2 py-0.5 bg-warm-white text-text-mid text-xs rounded-full mb-3 capitalize">
          {roleType}
        </span>
      )}
      <p class="text-text-mid text-sm leading-relaxed">{bio}</p>
    </div>
  </div>
</div>
