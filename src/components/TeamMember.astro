---
interface Props {
  name: string;
  title: string;
  bio: string;
  roleType?: string;
}

const { name, title, bio, roleType = 'staff' } = Astro.props;
---

<div class="bg-white rounded-2xl border border-sage p-6 hover:shadow-md transition-shadow">
  <div class="flex items-start gap-5">
    <!-- Photo placeholder -->
    <div class="w-20 h-20 bg-gradient-to-br from-teal-primary/20 to-sage rounded-xl flex items-center justify-center shrink-0">
      <span class="text-teal-primary font-bold text-xl font-serif">
        {name.split(' ').map(n => n[0]).join('')}
      </span>
    </div>
    <div>
      <h3 class="text-lg font-bold text-charcoal">{name}</h3>
      <p class="text-teal-primary text-sm font-medium mb-2">{title}</p>
      {roleType && (
        <span class="inline-block px-2 py-0.5 bg-sage text-charcoal/60 text-xs rounded-full mb-3 capitalize">
          {roleType}
        </span>
      )}
      <p class="text-charcoal/60 text-sm leading-relaxed">{bio}</p>
    </div>
  </div>
</div>
