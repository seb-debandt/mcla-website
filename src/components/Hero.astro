---
interface Props {
  title: string;
  highlight: string;
  description: string;
  primaryText: string;
  primaryUrl: string;
  secondaryText: string;
  secondaryUrl: string;
}

const { title, highlight, description, primaryText, primaryUrl, secondaryText, secondaryUrl } = Astro.props;

// Split highlight into two color parts: "mantle cell" in teal, "lymphoma." in amber
const highlightLower = highlight.toLowerCase();
const mantleCellIdx = highlightLower.indexOf('mantle cell');
const lymphomaIdx = highlightLower.indexOf('lymphoma');

let tealPart = '';
let amberPart = '';

if (mantleCellIdx !== -1 && lymphomaIdx !== -1) {
  tealPart = highlight.substring(mantleCellIdx, mantleCellIdx + 'mantle cell'.length);
  amberPart = highlight.substring(lymphomaIdx);
} else {
  tealPart = highlight;
}
---
<section class="bg-cream overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 md:py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Left: Text content -->
      <div class="relative z-10">
        <h1 class="text-[36px] md:text-[48px] lg:text-[56px] font-black text-text-dark leading-[1.08] tracking-[-1.5px] mb-6">
          {title}{' '}
          {amberPart ? (
            <>
              <span class="text-teal">{tealPart}</span>{' '}
              <span class="text-amber">{amberPart}</span>
            </>
          ) : (
            <span class="text-teal">{tealPart}</span>
          )}
        </h1>
        <p class="text-[17px] md:text-[19px] text-text-mid leading-[1.7] mb-10 max-w-lg">
          {description}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={primaryUrl}
            class="inline-flex items-center justify-center px-9 py-4 bg-teal text-white font-bold rounded-full hover:bg-teal-light transition-all duration-200 hover:-translate-y-[1px] no-underline text-base tracking-[0.3px]"
          >
            {primaryText}
          </a>
          <a
            href={secondaryUrl}
            class="inline-flex items-center justify-center px-9 py-4 border-[2.5px] border-amber text-amber font-bold rounded-full hover:bg-amber hover:text-white transition-all duration-200 no-underline text-base tracking-[0.3px]"
          >
            {secondaryText}
          </a>
        </div>
      </div>

      <!-- Right: Photo montage -->
      <div class="hidden lg:block">
        <img src="/uploads/heroes/montage.jpg" alt="MCLA community members — patients, caregivers, and supporters" class="w-full h-auto rounded-2xl shadow-[0_8px_30px_rgba(0,0,0,0.12)]" loading="eager" />
      </div>

      <!-- Mobile: Photo montage -->
      <div class="lg:hidden -mx-2">
        <img src="/uploads/heroes/montage.jpg" alt="MCLA community members — patients, caregivers, and supporters" class="w-full h-auto rounded-2xl shadow-lg" loading="eager" />
      </div>
    </div>
  </div>
</section>
