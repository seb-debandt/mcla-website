---
---
<section class="relative overflow-hidden bg-gradient-to-br from-teal-primary/5 via-warm-white to-sage/30 py-20 md:py-28 lg:py-36">
  <!-- Subtle decorative shapes -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-teal-primary/5 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-gold/5 rounded-full translate-y-1/2 -translate-x-1/3 blur-3xl" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-charcoal leading-[1.1] mb-6">
        Advancing hope for those facing
        <span class="text-teal-primary">mantle cell lymphoma.</span>
      </h1>
      <p class="text-lg md:text-xl text-charcoal/70 leading-relaxed mb-10 max-w-2xl">
        We connect patients, caregivers, and researchers with trusted information, expert-guided support, and the research needed to improve outcomes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/understanding-mcl/what-is-mcl"
          class="inline-flex items-center justify-center px-7 py-3.5 bg-teal-primary text-white font-semibold rounded-lg hover:bg-teal-dark transition-colors no-underline text-base"
        >
          Learn About MCL
        </a>
        <a
          href="/donate"
          class="inline-flex items-center justify-center px-7 py-3.5 border-2 border-coral text-coral font-semibold rounded-lg hover:bg-coral hover:text-white transition-colors no-underline text-base"
        >
          Support Our Mission
        </a>
      </div>
    </div>
  </div>
</section>
