---
interface Props {
  title: string;
  highlight: string;
  description: string;
  primaryText: string;
  primaryUrl: string;
  secondaryText: string;
  secondaryUrl: string;
}

const { title, highlight, description, primaryText, primaryUrl, secondaryText, secondaryUrl } = Astro.props;

// Split highlight into two color parts: "mantle cell" in teal, "lymphoma." in amber
const highlightLower = highlight.toLowerCase();
const mantleCellIdx = highlightLower.indexOf('mantle cell');
const lymphomaIdx = highlightLower.indexOf('lymphoma');

let tealPart = '';
let amberPart = '';

if (mantleCellIdx !== -1 && lymphomaIdx !== -1) {
  tealPart = highlight.substring(mantleCellIdx, mantleCellIdx + 'mantle cell'.length);
  amberPart = highlight.substring(lymphomaIdx);
} else {
  tealPart = highlight;
}
---
<section class="bg-cream overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 md:py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Left: Text content -->
      <div class="relative z-10">
        <h1 class="text-[36px] md:text-[48px] lg:text-[56px] font-black text-text-dark leading-[1.08] tracking-[-1.5px] mb-6">
          {title}{' '}
          {amberPart ? (
            <>
              <span class="text-teal">{tealPart}</span>{' '}
              <span class="text-amber">{amberPart}</span>
            </>
          ) : (
            <span class="text-teal">{tealPart}</span>
          )}
        </h1>
        <p class="text-[17px] md:text-[19px] text-text-mid leading-[1.7] mb-10 max-w-lg">
          {description}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={primaryUrl}
            class="inline-flex items-center justify-center px-9 py-4 bg-teal text-white font-bold rounded-full hover:bg-teal-light transition-all duration-200 hover:-translate-y-[1px] no-underline text-base tracking-[0.3px]"
          >
            {primaryText}
          </a>
          <a
            href={secondaryUrl}
            class="inline-flex items-center justify-center px-9 py-4 border-[2.5px] border-amber text-amber font-bold rounded-full hover:bg-amber hover:text-white transition-all duration-200 no-underline text-base tracking-[0.3px]"
          >
            {secondaryText}
          </a>
        </div>
      </div>

      <!-- Right: Photo collage -->
      <div class="hidden lg:block relative" style="height: 540px;">
        <!-- Row 1: Three photos across the top -->
        <!-- Photo 1: Woman with glasses — large, top-left -->
        <div class="absolute rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.12)] border-[3px] border-white z-30"
             style="top: 0; left: 2%; width: 48%; height: 280px; transform: rotate(-2deg);">
          <img src="/uploads/heroes/patient-1.jpg" alt="MCLA community member" class="w-full h-full object-cover object-top block" loading="eager" />
        </div>

        <!-- Photo 2: Warriors flexing — small, top-center -->
        <div class="absolute rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.12)] border-[3px] border-white z-20"
             style="top: 10px; left: 44%; width: 28%; height: 180px; transform: rotate(3deg);">
          <img src="/uploads/heroes/patient-2.jpg" alt="MCLA community members" class="w-full h-full object-cover object-top block" loading="eager" />
        </div>

        <!-- Photo 3: Couple Las Vegas — top-right -->
        <div class="absolute rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.12)] border-[3px] border-white z-10"
             style="top: -5px; right: -3%; width: 30%; height: 220px; transform: rotate(4deg);">
          <img src="/uploads/heroes/patient-3.jpg" alt="MCLA community members" class="w-full h-full object-cover object-top block" loading="eager" />
        </div>

        <!-- Row 2: Two photos on the bottom -->
        <!-- Photo 4: Couple at dinner — bottom-left -->
        <div class="absolute rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.12)] border-[3px] border-white z-20"
             style="bottom: 20px; left: 8%; width: 38%; height: 220px; transform: rotate(2deg);">
          <img src="/uploads/heroes/patient-5.jpg" alt="MCLA community members" class="w-full h-full object-cover object-center block" loading="lazy" />
        </div>

        <!-- Photo 5: Fishing woman — bottom-right -->
        <div class="absolute rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.12)] border-[3px] border-white z-30"
             style="bottom: 10px; right: 2%; width: 36%; height: 230px; transform: rotate(-3deg);">
          <img src="/uploads/heroes/patient-4.jpg" alt="MCLA community member" class="w-full h-full object-cover object-top block" loading="lazy" />
        </div>
      </div>

      <!-- Mobile: scrolling photo strip -->
      <div class="lg:hidden flex gap-4 overflow-x-auto pb-4 -mx-6 px-6 snap-x snap-mandatory scrollbar-hide">
        <div class="flex-none w-48 snap-start rounded-2xl overflow-hidden shadow-lg border-[3px] border-white rotate-[-1deg]">
          <img src="/uploads/heroes/patient-1.jpg" alt="MCLA community member" class="w-full h-60 object-cover" loading="eager" />
        </div>
        <div class="flex-none w-48 snap-start rounded-2xl overflow-hidden shadow-lg border-[3px] border-white rotate-[1deg]">
          <img src="/uploads/heroes/patient-2.jpg" alt="MCLA community members" class="w-full h-60 object-cover" loading="eager" />
        </div>
        <div class="flex-none w-48 snap-start rounded-2xl overflow-hidden shadow-lg border-[3px] border-white rotate-[-1deg]">
          <img src="/uploads/heroes/patient-3.jpg" alt="MCLA community members" class="w-full h-60 object-cover" loading="eager" />
        </div>
        <div class="flex-none w-48 snap-start rounded-2xl overflow-hidden shadow-lg border-[3px] border-white rotate-[1deg]">
          <img src="/uploads/heroes/patient-5.jpg" alt="MCLA community members" class="w-full h-60 object-cover" loading="lazy" />
        </div>
        <div class="flex-none w-48 snap-start rounded-2xl overflow-hidden shadow-lg border-[3px] border-white rotate-[-1deg]">
          <img src="/uploads/heroes/patient-4.jpg" alt="MCLA community member" class="w-full h-60 object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
