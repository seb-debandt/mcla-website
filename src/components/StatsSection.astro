---
interface Props {
  heading: string;
  subheading: string;
  stats: { value: string; label: string }[];
  source: string;
}

const { heading, subheading, stats, source } = Astro.props;
---

<section class="py-20 md:py-24 bg-teal-deep">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="text-center mb-14">
      <div class="section-label">BY THE NUMBERS</div>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white/90 tracking-[-0.5px] leading-[1.15] mb-4">{heading}</h2>
      <p class="text-white/65 text-lg max-w-2xl mx-auto">
        {subheading}
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-0">
      {stats.map((stat, i) => (
        <div class:list={['text-center py-6 px-4', i < stats.length - 1 && 'lg:border-r lg:border-white/10']}>
          <div class="text-[36px] md:text-[48px] font-black text-amber-light mb-2 tracking-[-1px]">{stat.value}</div>
          <div class="text-white/65 text-sm md:text-[14px] font-medium tracking-[0.3px]">{stat.label}</div>
        </div>
      ))}
    </div>

    <p class="text-center text-white/35 text-[13px] mt-12 italic">
      {source}
    </p>
  </div>
</section>
