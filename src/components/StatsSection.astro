---
interface Props {
  heading: string;
  subheading: string;
  stats: { value: string; label: string }[];
  source: string;
}

const { heading, subheading, stats, source } = Astro.props;
---

<section class="py-20 md:py-24 bg-teal-primary relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-teal-dark/50 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{heading}</h2>
      <p class="text-white/70 text-lg max-w-2xl mx-auto">
        {subheading}
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-bold text-white mb-2 font-serif">{stat.value}</div>
          <div class="text-white/70 text-sm md:text-base">{stat.label}</div>
        </div>
      ))}
    </div>

    <p class="text-center text-white/40 text-xs mt-12">
      {source}
    </p>
  </div>
</section>
