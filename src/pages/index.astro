---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PillarCards from '../components/PillarCards.astro';
import StatsSection from '../components/StatsSection.astro';
import NewsCards from '../components/NewsCards.astro';
import DonateForm from '../components/DonateForm.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'home');
if (page.data.draft) return Astro.redirect('/404');
---

<BaseLayout title="Home">
  <Hero
    title={page.data.heroTitle}
    highlight={page.data.heroHighlight}
    description={page.data.heroDescription}
    primaryText={page.data.heroPrimaryText}
    primaryUrl={page.data.heroPrimaryUrl}
    secondaryText={page.data.heroSecondaryText}
    secondaryUrl={page.data.heroSecondaryUrl}
  />

  <!-- Mission Statement -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
      <p class="text-xl md:text-2xl text-text-dark/80 leading-[1.7] font-medium">
        {page.data.missionStatement}
      </p>
    </div>
  </section>

  <PillarCards
    heading={page.data.pillarsHeading}
    subheading={page.data.pillarsSubheading}
    pillars={page.data.pillars}
  />
  <StatsSection
    heading={page.data.statsHeading}
    subheading={page.data.statsSubheading}
    stats={page.data.stats}
    source={page.data.statsSource}
  />
  <NewsletterSignup />
</BaseLayout>
