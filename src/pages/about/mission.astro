---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Mission"
  description="The MCLA mission: supporting those facing mantle cell lymphoma with trusted information, expert-guided support, and targeted research."
>
  <!-- Page Header -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-teal-primary/5 via-warm-white to-sage/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-6">Our Mission</h1>
      <p class="text-xl text-charcoal/60 leading-relaxed">
        Driving progress in the fight against mantle cell lymphoma through research, education, and community.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Mission Statement -->
      <div class="bg-sage/30 rounded-2xl p-8 md:p-12 mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Mission Statement</h2>
        <p class="text-lg text-charcoal/80 leading-relaxed">
          The Mantle Cell Lymphoma Alliance supports those facing mantle cell lymphoma with trusted information and expert-guided support. We connect patients, caregivers, researchers, and oncologists across all clinical settings to improve outcomes and expand access to care. We support targeted research that advances progress toward better treatments and ultimately a cure.
        </p>
      </div>

      <!-- Vision -->
      <div class="mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-6">Our Vision</h2>
        <p class="text-lg text-charcoal/70 leading-relaxed">
          A world where every person affected by mantle cell lymphoma has access to the best information, the most experienced specialists, and the most promising treatments — and where targeted research leads to a cure.
        </p>
      </div>

      <!-- Values -->
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-charcoal mb-8">Our Values</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl border border-sage p-6">
            <h3 class="text-lg font-bold text-charcoal mb-2">Patient-Centered</h3>
            <p class="text-charcoal/60 text-[15px]">Every decision we make starts with the needs of patients and their families. Their voices guide our priorities.</p>
          </div>
          <div class="bg-white rounded-xl border border-sage p-6">
            <h3 class="text-lg font-bold text-charcoal mb-2">Science-Driven</h3>
            <p class="text-charcoal/60 text-[15px]">We ground our work in evidence and partner with leading researchers and clinicians to ensure accuracy and rigor.</p>
          </div>
          <div class="bg-white rounded-xl border border-sage p-6">
            <h3 class="text-lg font-bold text-charcoal mb-2">Collaborative</h3>
            <p class="text-charcoal/60 text-[15px]">We bring together patients, caregivers, researchers, and clinicians because progress requires partnership.</p>
          </div>
          <div class="bg-white rounded-xl border border-sage p-6">
            <h3 class="text-lg font-bold text-charcoal mb-2">Transparent</h3>
            <p class="text-charcoal/60 text-[15px]">We communicate honestly about both progress and challenges. Trust is the foundation of everything we do.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
