---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const stories = (await getCollection('blog'))
  .filter((post) => post.data.category === 'Patient Stories')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="Patient Stories"
  description="Real stories from people living with mantle cell lymphoma. Hear from MCL patients, caregivers, and survivors about diagnosis, treatment, and life after."
>
  <section class="py-16 md:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text-dark tracking-[-0.5px] mb-6">Patient Stories</h1>
      <p class="text-xl text-text-mid leading-relaxed">
        MCL touches every life differently. These are first-person stories from our community — what diagnosis felt like, how treatment unfolded, what helped, and what they wish they'd known. We share them because no one should face MCL alone, and because hearing from people who have walked this path can be one of the most powerful resources of all.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-12">
      {stories.length === 0 && (
        <div class="text-center py-16">
          <p class="text-text-light text-lg">Patient stories coming soon. Want to share yours? <a href="/contact" class="text-teal font-semibold no-underline hover:underline">Get in touch.</a></p>
        </div>
      )}

      <div class="space-y-12">
        {stories.map((story) => (
          <a
            href={`/news/${story.id}`}
            class="group block bg-white rounded-2xl overflow-hidden border border-border hover:shadow-lg transition-all duration-300 no-underline md:flex"
          >
            {story.data.featuredImage && (
              <div class="md:w-2/5 aspect-[4/5] md:aspect-auto bg-gradient-to-br from-teal/20 to-warm-white overflow-hidden">
                <img
                  src={story.data.featuredImage}
                  alt=""
                  class="w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-8 md:p-10 md:w-3/5 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-2.5 py-0.5 bg-teal/10 text-teal text-xs font-semibold rounded-full">
                  Patient Story
                </span>
                <time class="text-text-light text-xs" datetime={new Date(story.data.date).toISOString()}>
                  {new Date(story.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <h2 class="text-2xl md:text-3xl font-extrabold text-text-dark mb-3 group-hover:text-teal transition-colors leading-tight">{story.data.title}</h2>
              <p class="text-text-mid leading-relaxed mb-4">{story.data.excerpt}</p>
              <div class="text-sm text-text-light mb-4">— {story.data.author}</div>
              <div class="text-teal font-semibold">Read {story.data.author.split(',')[0].split(' ')[0]}'s story &rarr;</div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-20 pt-12 border-t border-border text-center">
        <h2 class="text-2xl md:text-3xl font-extrabold text-text-dark mb-3">Want to share your story?</h2>
        <p class="text-text-mid leading-relaxed mb-6 max-w-2xl mx-auto">
          If you've been diagnosed with MCL — or you've cared for someone who has — your story could help someone who is just starting their journey. We'd love to hear from you.
        </p>
        <a
          href="/contact"
          class="inline-block bg-teal text-white px-6 py-3 rounded-lg font-semibold no-underline hover:bg-teal-deep transition-colors"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
