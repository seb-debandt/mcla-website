---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'partner');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="py-16 md:py-20 bg-gradient-to-br from-teal-primary/5 via-warm-white to-sage/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-6">{page.data.title}</h1>
      <p class="text-xl text-charcoal/60 leading-relaxed">{page.data.subtitle}</p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose max-w-none">
        <Content />
      </div>
      {page.data.ctaText && page.data.ctaUrl && (
        <div class="bg-sage/30 rounded-xl p-6 my-8">
          <h3 class="text-lg font-bold text-charcoal mb-3">Let's Talk</h3>
          <p class="text-charcoal/70 mb-4">
            Interested in partnering with MCLA? We'd love to hear from you. Contact us to discuss how we can work together.
          </p>
          <a
            href={page.data.ctaUrl}
            class="inline-flex items-center px-6 py-2.5 bg-teal-primary text-white font-semibold rounded-lg hover:bg-teal-dark transition-colors no-underline text-sm"
          >
            {page.data.ctaText}
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
