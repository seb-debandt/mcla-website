---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'get-involved');

const iconSvgs = [
  '<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M10.05 4.575a1.575 1.575 0 1 0-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 0 1 3.15 0v1.5m-3.15 0 .075 5.925m3.075.75V4.575m0 0a1.575 1.575 0 0 1 3.15 0V15M6.9 7.575a1.575 1.575 0 1 0-3.15 0v8.175a6.75 6.75 0 0 0 6.75 6.75h2.018a5.25 5.25 0 0 0 3.712-1.538l1.732-1.732a5.25 5.25 0 0 0 1.538-3.712l.003-2.024a.668.668 0 0 0-.668-.668 1.667 1.667 0 0 1-1.667-1.667V8.724a1.5 1.5 0 0 0-1.5-1.5H15M6.9 7.575V12" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" />'
];

const iconColors = ['coral', 'teal-primary', 'teal-primary', 'gold', 'gold', 'gold'];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="py-16 md:py-20 bg-gradient-to-br from-teal-primary/5 via-warm-white to-sage/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-6">{page.data.title}</h1>
      <p class="text-xl text-charcoal/60 leading-relaxed">{page.data.subtitle}</p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {page.data.ways.map((way: { name: string; description: string; url?: string; contactUrl?: string; contactText?: string }, i: number) => {
          const color = iconColors[i] || 'teal-primary';
          const isLink = !!way.url;
          const Tag = isLink ? 'a' : 'div';
          return isLink ? (
            <a href={way.url} class={`group block bg-white rounded-2xl border border-sage p-8 hover:shadow-lg hover:border-${color}/30 transition-all no-underline`}>
              <div class={`w-14 h-14 bg-${color}/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-${color}/20 transition-colors`}>
                <svg class={`w-7 h-7 text-${color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><Fragment set:html={iconSvgs[i]} /></svg>
              </div>
              <h3 class="text-xl font-bold text-charcoal mb-2">{way.name}</h3>
              <p class="text-charcoal/60 text-[15px]">{way.description}</p>
            </a>
          ) : (
            <div class="bg-white rounded-2xl border border-sage p-8">
              <div class={`w-14 h-14 bg-${color}/10 rounded-xl flex items-center justify-center mb-6`}>
                <svg class={`w-7 h-7 text-${color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><Fragment set:html={iconSvgs[i]} /></svg>
              </div>
              <h3 class="text-xl font-bold text-charcoal mb-2">{way.name}</h3>
              <p class="text-charcoal/60 text-[15px] mb-4">{way.description}</p>
              {way.contactUrl && way.contactText && (
                <a href={way.contactUrl} class="text-teal-primary font-semibold text-sm no-underline hover:underline">{way.contactText} &rarr;</a>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
