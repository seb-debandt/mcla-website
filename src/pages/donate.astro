---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'donate');
if (page.data.draft) return Astro.redirect('/404');
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="py-16 md:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text-dark tracking-[-0.5px] mb-6">{page.data.title}</h1>
      <p class="text-xl text-text-mid leading-relaxed">{page.data.subtitle}</p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3">
          <givebutter-widget id="pXv4X4"></givebutter-widget>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="bg-warm-white rounded-2xl p-6">
            <h3 class="text-lg font-extrabold text-text-dark mb-4">Why Your Gift Matters</h3>
            <p class="text-text-mid text-sm leading-relaxed mb-4">{page.data.whyGiftMatters}</p>
            <ul class="text-text-mid text-sm space-y-2">
              {page.data.impactAreas.map((area: string) => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  {area}
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-white rounded-2xl border border-border p-6">
            <h3 class="text-lg font-extrabold text-text-dark mb-3">Other Ways to Give</h3>
            <ul class="text-text-mid text-sm space-y-3">
              {page.data.otherWays.map((way: { method: string; description: string }) => (
                <li><strong>{way.method}:</strong> {way.description}</li>
              ))}
            </ul>
          </div>

          <p class="text-xs text-text-light text-center">
            Questions about giving? Contact us at<br />
            <a href={`mailto:${page.data.donateEmail}`} class="text-teal no-underline">{page.data.donateEmail}</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
