---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MedicalDisclaimer from '../../components/MedicalDisclaimer.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'caregiver-support');
if (page.data.draft) return Astro.redirect('/404');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="py-16 md:py-20 bg-gradient-to-br from-teal-primary/5 via-warm-white to-sage/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-charcoal mb-6">{page.data.title}</h1>
      <p class="text-xl text-charcoal/60 leading-relaxed">{page.data.subtitle}</p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose max-w-none">
        <Content />
      </div>

      {page.data.resources && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
          {page.data.resources.map((resource: { name: string; description: string }) => (
            <div class="bg-sage/30 rounded-xl p-5">
              <h3 class="text-base font-bold text-charcoal mb-2">{resource.name}</h3>
              <p class="text-charcoal/60 text-sm">{resource.description}</p>
            </div>
          ))}
        </div>
      )}

      {page.data.ctaText && page.data.ctaUrl && (
        <div class="bg-sage/30 rounded-xl p-6 my-8">
          <h3 class="text-lg font-bold text-charcoal mb-3">We're Here for You</h3>
          <p class="text-charcoal/70 mb-4">
            MCLA is building resources specifically for caregivers. If you need support or have questions, please reach out.
          </p>
          <a
            href={page.data.ctaUrl}
            class="inline-flex items-center px-6 py-2.5 bg-teal-primary text-white font-semibold rounded-lg hover:bg-teal-dark transition-colors no-underline text-sm"
          >
            {page.data.ctaText}
          </a>
        </div>
      )}

      {page.data.showMedicalDisclaimer && <MedicalDisclaimer />}
    </div>
  </section>
</BaseLayout>
