---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MedicalDisclaimer from '../../components/MedicalDisclaimer.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'what-is-mcl');
if (page.data.draft) return Astro.redirect('/404');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="py-16 md:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text-dark tracking-[-0.5px] mb-6">{page.data.title}</h1>
      <p class="text-xl text-text-mid leading-relaxed">{page.data.subtitle}</p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <div class="prose max-w-none">
        <Content />
      </div>
      {page.data.showMedicalDisclaimer && <MedicalDisclaimer />}
    </div>
  </section>
</BaseLayout>
