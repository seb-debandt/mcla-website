---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'for-researchers');
if (page.data.draft) return Astro.redirect('/404');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="py-16 md:py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text-dark tracking-[-0.5px] mb-6">{page.data.title}</h1>
      <p class="text-xl text-text-mid leading-relaxed">{page.data.subtitle}</p>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <div class="prose max-w-none">
        <Content />
      </div>
      {page.data.ctaText && page.data.ctaUrl && (
        <div class="bg-warm-white rounded-xl p-6 my-8">
          <h3 class="text-lg font-extrabold text-text-dark mb-3">Get in Touch</h3>
          <p class="text-text-mid mb-4">
            We'd love to hear from researchers interested in collaborating with MCLA. Please contact us to discuss partnership opportunities.
          </p>
          <a
            href={page.data.ctaUrl}
            class="inline-flex items-center px-6 py-2.5 bg-teal text-white font-semibold rounded-full hover:bg-teal-light transition-colors no-underline text-sm"
          >
            {page.data.ctaText}
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
